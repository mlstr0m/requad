diff --git a/quadwild/functions.cpp b/quadwild/functions.cpp
index 20331fb..e7fef50 100644
--- a/quadwild/functions.cpp
+++ b/quadwild/functions.cpp
@@ -18,10 +18,33 @@ inline void remeshAndField(
     BPar.sharp_feature_thr=parameters.sharpAngle;
     BPar.surf_dist_check=true;
     BPar.UpdateSharp=(!parameters.hasFeature);
+    if (parameters.remeshTargetFaces>0)
+    {
+        // Same equilateral-triangle estimate as AutoRemesher::ExpectedEdgeL:
+        // area of N equilateral triangles of edge L is N*L^2/2.309.
+        // Coarsen-only: never go denser than the automatic estimate, so
+        // high quad targets keep the historic behavior and performance.
+        typename FieldTriMesh::ScalarType area=trimesh.Area();
+        if (area>0)
+        {
+            typename FieldTriMesh::ScalarType custom=
+                std::sqrt(area*(typename FieldTriMesh::ScalarType)2.309
+                          /parameters.remeshTargetFaces);
+            typename FieldTriMesh::ScalarType autoL=
+                AutoRemesher<FieldTriMesh>::ExpectedEdgeL(trimesh);
+            BPar.remesher_target_edge_len=std::max(custom,autoL);
+        }
+    }
 
     typename vcg::tri::FieldSmoother<FieldTriMesh>::SmoothParam FieldParam;
     FieldParam.alpha_curv=0.3;
     FieldParam.curv_thr=0.8;
+    if (parameters.fieldCurvAlpha>=0)
+    {
+        // AutoSetupParam replaces an exact 0 with the 0.3 default, so clamp
+        // "no curvature alignment" to a tiny positive weight instead.
+        FieldParam.alpha_curv=std::max(parameters.fieldCurvAlpha,0.0001f);
+    }
 
     if (parameters.hasFeature) {
         bool loaded=trimesh.LoadSharpFeatures(sharpFilename);
@@ -247,6 +270,15 @@ inline bool loadConfigFile(const std::string& filename, Parameters& parameters)
 
     fscanf(f,"scaleFact %f\n",&parameters.scaleFact);
 
+    // optional trailing keys (older config files simply omit them)
+    int targetFaces=0;
+    if (fscanf(f,"remesh_target_faces %d\n",&targetFaces)==1 && targetFaces>0)
+        parameters.remeshTargetFaces=targetFaces;
+
+    float curvAlpha=-1;
+    if (fscanf(f,"field_curv_align %f\n",&curvAlpha)==1 && curvAlpha>=0)
+        parameters.fieldCurvAlpha=curvAlpha;
+
     fclose(f);
 
     std::cout << "Successful config import" << std::endl;
diff --git a/quadwild/functions.h b/quadwild/functions.h
index 16aaffc..cd18687 100644
--- a/quadwild/functions.h
+++ b/quadwild/functions.h
@@ -18,6 +18,8 @@ struct Parameters {
         sharpAngle(35),
         alpha(0.02),
         scaleFact(1),
+        remeshTargetFaces(0),
+        fieldCurvAlpha(-1),
         hasFeature(false),
         hasField(false)
     {
@@ -28,6 +30,14 @@ struct Parameters {
     float sharpAngle;
     float alpha;
     float scaleFact;
+    // 0 keeps the automatic (ExpectedEdgeL) pre-remesh density; a positive
+    // value asks the pre-remesh for approximately this many triangles, so
+    // that field/tracing granularity can follow the requested output density.
+    int remeshTargetFaces;
+    // <0 keeps the historic curvature-alignment weight (0.3). >=0 overrides
+    // it; lower values give a smoother field with fewer singularities, which
+    // lowers the minimum reachable quad count on organic shapes.
+    float fieldCurvAlpha;
     bool hasFeature;
     bool hasField;
 };
